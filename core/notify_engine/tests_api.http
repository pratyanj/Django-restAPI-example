##########################################################################
#  Notify Engine — API Test Suite
#  Base URL: http://127.0.0.1:8000/api/notify
#
#  Run these requests top-to-bottom. IDs in later requests reference
#  objects created by earlier ones — update {{id}} placeholders after
#  each create call with the actual ID from the response.
##########################################################################

@baseUrl = http://127.0.0.1:8000/api/notify
@contentType = application/json


### ======================================================================
###  1. EMAIL RULES (EmailMaster) — Full CRUD
### ======================================================================

### 1.1  CREATE — Email Rule (enquiry_created event)
POST {{baseUrl}}/email-rules/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "enquiry_created",
    "module_name": "crm",
    "is_active": true,
    "to_send": true,
    "to_type": "dynamic",
    "to_value": "email",
    "is_cc": true,
    "cc_type": "static",
    "cc_value": "manager@example.com",
    "subject_template": "New Enquiry from {{name}}",
    "body_template": "<h1>New Enquiry Received</h1><p><b>Name:</b> {{name}}</p><p><b>Email:</b> {{email}}</p><p><b>Phone:</b> {{phone}}</p><p><b>Message:</b> {{message}}</p>",
    "attach_pdf": false,
    "pdf_template_code": ""
}

### 1.2  CREATE — Email Rule (order_placed event, with PDF)
POST {{baseUrl}}/email-rules/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "order_placed",
    "module_name": "sales",
    "is_active": true,
    "to_send": true,
    "to_type": "static",
    "to_value": "sales@example.com",
    "is_cc": false,
    "cc_type": "",
    "cc_value": "",
    "subject_template": "Order Confirmation #{{order_number}}",
    "body_template": "<h1>Order Placed</h1><p>Order <b>{{order_number}}</b> has been placed by {{customer_name}}.</p>",
    "attach_pdf": true,
    "pdf_template_code": "invoice_pdf"
}

### 1.3  LIST — All email rules
GET {{baseUrl}}/email-rules/ HTTP/1.1
Accept: {{contentType}}

### 1.4  LIST — Filter by module_name
GET {{baseUrl}}/email-rules/?module_name=crm HTTP/1.1
Accept: {{contentType}}

### 1.5  LIST — Filter by is_active
GET {{baseUrl}}/email-rules/?is_active=true HTTP/1.1
Accept: {{contentType}}

### 1.6  LIST — Filter by to_type
GET {{baseUrl}}/email-rules/?to_type=dynamic HTTP/1.1
Accept: {{contentType}}

### 1.7  LIST — Search across event_name, module_name, subject_template
GET {{baseUrl}}/email-rules/?search=enquiry HTTP/1.1
Accept: {{contentType}}

### 1.8  LIST — Ordering by created_at descending
GET {{baseUrl}}/email-rules/?ordering=-created_at HTTP/1.1
Accept: {{contentType}}

### 1.9  RETRIEVE — Get a single email rule (update the ID!)
# ⚠️ Replace 1 with the actual ID from the create response
GET {{baseUrl}}/email-rules/1/ HTTP/1.1
Accept: {{contentType}}

### 1.10  UPDATE (PUT) — Full update of an email rule
# ⚠️ Replace 1 with the actual ID
PUT {{baseUrl}}/email-rules/1/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "enquiry_created",
    "module_name": "crm",
    "is_active": true,
    "to_send": true,
    "to_type": "dynamic",
    "to_value": "email",
    "is_cc": true,
    "cc_type": "static",
    "cc_value": "manager@example.com,admin@example.com",
    "subject_template": "[CRM] New Enquiry from {{name}} — {{email}}",
    "body_template": "<h1>New Enquiry</h1><p><b>Name:</b> {{name}}</p><p><b>Email:</b> {{email}}</p><p><b>Phone:</b> {{phone}}</p><p><b>Message:</b></p><blockquote>{{message}}</blockquote><hr><p><small>This is an automated notification.</small></p>",
    "attach_pdf": true,
    "pdf_template_code": "enquiry_pdf"
}

### 1.11  PARTIAL UPDATE (PATCH) — Toggle to_send off
# ⚠️ Replace 1 with the actual ID
PATCH {{baseUrl}}/email-rules/1/ HTTP/1.1
Content-Type: {{contentType}}

{
    "to_send": false
}

### 1.12  TOGGLE ACTIVE — Custom action to flip is_active
# ⚠️ Replace 1 with the actual ID
POST {{baseUrl}}/email-rules/1/toggle-active/ HTTP/1.1
Content-Type: {{contentType}}

### 1.13  DELETE — Remove an email rule
# ⚠️ Replace 2 with the ID of the order_placed rule
DELETE {{baseUrl}}/email-rules/2/ HTTP/1.1


### ======================================================================
###  2. TEMPLATE TAGS (EmailTemplateTag) — Full CRUD
### ======================================================================

### 2.1  CREATE — Template tag for customer name
POST {{baseUrl}}/template-tags/ HTTP/1.1
Content-Type: {{contentType}}

{
    "tag_name": "customer_name",
    "source_table": "crm.Customer",
    "source_field": "full_name",
    "relation_key": "customer",
    "module_name": "crm"
}

### 2.2  CREATE — Template tag for customer email
POST {{baseUrl}}/template-tags/ HTTP/1.1
Content-Type: {{contentType}}

{
    "tag_name": "customer_email",
    "source_table": "crm.Customer",
    "source_field": "email",
    "relation_key": "customer",
    "module_name": "crm"
}

### 2.3  CREATE — Template tag for order number
POST {{baseUrl}}/template-tags/ HTTP/1.1
Content-Type: {{contentType}}

{
    "tag_name": "order_number",
    "source_table": "sales.Order",
    "source_field": "order_number",
    "relation_key": "",
    "module_name": "sales"
}

### 2.4  LIST — All template tags
GET {{baseUrl}}/template-tags/ HTTP/1.1
Accept: {{contentType}}

### 2.5  LIST — Filter by module_name
GET {{baseUrl}}/template-tags/?module_name=crm HTTP/1.1
Accept: {{contentType}}

### 2.6  LIST — Filter by source_table
GET {{baseUrl}}/template-tags/?source_table=crm.Customer HTTP/1.1
Accept: {{contentType}}

### 2.7  LIST — Search
GET {{baseUrl}}/template-tags/?search=email HTTP/1.1
Accept: {{contentType}}

### 2.8  RETRIEVE — Get a single template tag
# ⚠️ Replace 1 with the actual ID
GET {{baseUrl}}/template-tags/1/ HTTP/1.1
Accept: {{contentType}}

### 2.9  UPDATE (PUT) — Full update
# ⚠️ Replace 1 with the actual ID
PUT {{baseUrl}}/template-tags/1/ HTTP/1.1
Content-Type: {{contentType}}

{
    "tag_name": "customer_name",
    "source_table": "crm.Customer",
    "source_field": "name",
    "relation_key": "customer",
    "module_name": "crm"
}

### 2.10  PARTIAL UPDATE (PATCH) — Change source_field
# ⚠️ Replace 1 with the actual ID
PATCH {{baseUrl}}/template-tags/1/ HTTP/1.1
Content-Type: {{contentType}}

{
    "source_field": "display_name"
}

### 2.11  DELETE — Remove a template tag
# ⚠️ Replace 3 with the ID of the order_number tag
DELETE {{baseUrl}}/template-tags/3/ HTTP/1.1


### ======================================================================
###  3. EMAIL LOGS (EmailLog) — Read-Only
### ======================================================================

### 3.1  LIST — All email logs
GET {{baseUrl}}/email-logs/ HTTP/1.1
Accept: {{contentType}}

### 3.2  LIST — Filter by status
GET {{baseUrl}}/email-logs/?status=sent HTTP/1.1
Accept: {{contentType}}

### 3.3  LIST — Filter by status (failed)
GET {{baseUrl}}/email-logs/?status=failed HTTP/1.1
Accept: {{contentType}}

### 3.4  LIST — Filter by status (pending)
GET {{baseUrl}}/email-logs/?status=pending HTTP/1.1
Accept: {{contentType}}

### 3.5  LIST — Filter by event_name
GET {{baseUrl}}/email-logs/?event_name=enquiry HTTP/1.1
Accept: {{contentType}}

### 3.6  LIST — Filter by to_email
GET {{baseUrl}}/email-logs/?to_email=test@example.com HTTP/1.1
Accept: {{contentType}}

### 3.7  LIST — Filter by date range
GET {{baseUrl}}/email-logs/?created_after=2026-01-01T00:00:00Z&created_before=2026-12-31T23:59:59Z HTTP/1.1
Accept: {{contentType}}

### 3.8  LIST — Search across event_name, to_email, subject
GET {{baseUrl}}/email-logs/?search=enquiry HTTP/1.1
Accept: {{contentType}}

### 3.9  LIST — Order by status
GET {{baseUrl}}/email-logs/?ordering=status HTTP/1.1
Accept: {{contentType}}

### 3.10  RETRIEVE — Get a single log entry
# ⚠️ Replace 1 with the actual ID
GET {{baseUrl}}/email-logs/1/ HTTP/1.1
Accept: {{contentType}}

### 3.11  POST — Should be REJECTED (logs are read-only)
# Expect: 405 Method Not Allowed
POST {{baseUrl}}/email-logs/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "test_event",
    "to_email": "hacker@example.com",
    "subject": "Should not work",
    "body": "This should return 405",
    "status": "sent"
}


### ======================================================================
###  4. ENQUIRY — Demo endpoint (triggers notification)
### ======================================================================

### 4.1  CREATE — New enquiry (triggers email notification if rule exists)
POST {{baseUrl}}/enquiry/ HTTP/1.1
Content-Type: {{contentType}}

{
    "name": "Pratyanj Kumar",
    "email": "pratyanj@example.com",
    "phone": "+91-9876543210",
    "message": "I am interested in your premium plan. Please send me the pricing details."
}

### 4.2  CREATE — Another enquiry (no phone)
POST {{baseUrl}}/enquiry/ HTTP/1.1
Content-Type: {{contentType}}

{
    "name": "John Doe",
    "email": "john.doe@example.com",
    "message": "Quick question about your API integration options."
}

### 4.3  CREATE — Should FAIL validation (missing required field)
# Expect: 400 Bad Request
POST {{baseUrl}}/enquiry/ HTTP/1.1
Content-Type: {{contentType}}

{
    "name": "No Email Person"
}


### ======================================================================
###  5. VALIDATION TESTS — Edge cases & error handling
### ======================================================================

### 5.1  CREATE — Should FAIL: CC enabled but missing cc_type
# Expect: 400 — "CC type is required when CC is enabled"
POST {{baseUrl}}/email-rules/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "test_validation_cc",
    "module_name": "test",
    "to_type": "static",
    "to_value": "test@example.com",
    "is_cc": true,
    "cc_type": "",
    "cc_value": "",
    "subject_template": "Test",
    "body_template": "Test body"
}

### 5.2  CREATE — Should FAIL: PDF enabled but missing template_code
# Expect: 400 — "PDF template code is required when PDF attachment is enabled"
POST {{baseUrl}}/email-rules/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "test_validation_pdf",
    "module_name": "test",
    "to_type": "static",
    "to_value": "test@example.com",
    "is_cc": false,
    "subject_template": "Test",
    "body_template": "Test body",
    "attach_pdf": true,
    "pdf_template_code": ""
}

### 5.3  CREATE — Should FAIL: Duplicate unique_together (event_name + module_name)
# Run this AFTER 1.1 succeeds — same event_name + module_name should fail
# Expect: 400 — unique constraint error
POST {{baseUrl}}/email-rules/ HTTP/1.1
Content-Type: {{contentType}}

{
    "event_name": "enquiry_created",
    "module_name": "crm",
    "to_type": "static",
    "to_value": "duplicate@example.com",
    "subject_template": "Duplicate rule",
    "body_template": "This should fail"
}

### 5.4  CREATE — Should FAIL: Duplicate tag_name (unique field)
# Run this AFTER 2.1 succeeds
# Expect: 400 — unique constraint error
POST {{baseUrl}}/template-tags/ HTTP/1.1
Content-Type: {{contentType}}

{
    "tag_name": "customer_name",
    "source_table": "crm.Customer",
    "source_field": "full_name",
    "relation_key": "customer",
    "module_name": "crm"
}

### 5.5  RETRIEVE — Non-existent email rule
# Expect: 404 Not Found
GET {{baseUrl}}/email-rules/99999/ HTTP/1.1
Accept: {{contentType}}

### 5.6  RETRIEVE — Non-existent template tag
# Expect: 404 Not Found
GET {{baseUrl}}/template-tags/99999/ HTTP/1.1
Accept: {{contentType}}

### 5.7  RETRIEVE — Non-existent email log
# Expect: 404 Not Found
GET {{baseUrl}}/email-logs/99999/ HTTP/1.1
Accept: {{contentType}}


### ======================================================================
###  6. PAGINATION TEST
### ======================================================================

### 6.1  LIST — Page 1 (default page_size=20)
GET {{baseUrl}}/email-rules/?page=1 HTTP/1.1
Accept: {{contentType}}

### 6.2  LIST — Page 2
GET {{baseUrl}}/email-rules/?page=2 HTTP/1.1
Accept: {{contentType}}
